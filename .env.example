# --- Required for live audits ---
ANTHROPIC_API_KEY=            # console.anthropic.com
OUTSCRAPER_API_KEY=           # app.outscraper.com -> API (free tier available)

# --- Required in production ---
DATABASE_URL=                 # Railway Postgres URL; omit locally to use SQLite (repdefense.db)
ADMIN_TOKEN=change-me         # protects /admin

# --- Optional ---
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_BASE_URL=           # set only if routing through a proxy (e.g. OpenRouter-compatible)
MAX_REVIEWS_PER_AUDIT=200
COMPETITOR_REVIEW_SAMPLE=60
PORT=8000
